# API 密钥配置模板
# 复制此文件为 .env.local 并填入您的实际 API 密钥
# 注意：客户端代码需要 NEXT_PUBLIC_ 前缀才能访问

# DeepSeek API（用于 AI 穿搭助手对话功能）
# 申请地址：https://platform.deepseek.com/
NEXT_PUBLIC_DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 豆包 ARK API（用于虚拟试穿图像生成）
# 申请地址：https://console.volcengine.com/ark
NEXT_PUBLIC_DOUBAO_ARK_API_KEY=your_doubao_ark_api_key_here
